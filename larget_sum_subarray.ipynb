   "source": [
    "def Largestsumsubarray(arr):\n",
    "    n = len(arr)\n",
    "    res = arr[0]\n",
    "    for i in range(n):\n",
    "        currsum = 0\n",
    "        for j in range(i,n):\n",
    "            currsum += arr[j]\n",
    "            res = max(res,currsum)\n",
    "            \n",
    "    return res\n",
    "    "
   ]
